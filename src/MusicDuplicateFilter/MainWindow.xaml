<Window x:Class="MusicDuplicateFilter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:MusicDuplicateFilter"
        xmlns:models="clr-namespace:MusicDuplicateFilter.Models"
        mc:Ignorable="d"
        Title="{Binding L[App.Title]}"
        Height="780" Width="1200"
        MinHeight="560" MinWidth="860"
        WindowStartupLocation="CenterScreen"
        Background="#F0F2F5">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />      <!-- 主内容区 (左+右) -->
            <RowDefinition Height="Auto" />   <!-- 底部状态栏 -->
        </Grid.RowDefinitions>

        <!-- ===== 主内容区：左侧目录面板 + 右侧结果面板 ===== -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230" />   <!-- 左：目录管理 -->
                <ColumnDefinition Width="10" />    <!-- 间距 -->
                <ColumnDefinition Width="*" />     <!-- 右：扫描结果 -->
            </Grid.ColumnDefinitions>

            <!-- ===== 左侧面板 ===== -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />      <!-- 目录列表卡片 -->
                    <RowDefinition Height="Auto" />   <!-- 操作按钮 -->
                </Grid.RowDefinitions>

                <!-- 目录列表卡片 -->
                <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />   <!-- 标题 -->
                            <RowDefinition Height="*" />      <!-- 列表 -->
                            <RowDefinition Height="Auto" />   <!-- 输入区 -->
                        </Grid.RowDefinitions>

                        <!-- 标题 -->
                        <Grid Grid.Row="0" Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding L[Main.DirectoryListHeader]}"
                                       FontSize="13" FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                            <Button Grid.Column="1" Content="清空"
                                    FontSize="11" Padding="6,2" Height="22"
                                    Background="Transparent" BorderThickness="1"
                                    BorderBrush="#DDD" Cursor="Hand" Foreground="#888"
                                    Command="{Binding ClearDirectoriesCommand}"
                                    IsEnabled="{Binding IsNotScanning}" />
                        </Grid>

                        <!-- 目录列表 -->
                        <Border Grid.Row="1"
                                BorderBrush="#E8E8E8" BorderThickness="1"
                                CornerRadius="4" Margin="0,0,0,8">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding ScanDirectories}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="4,3">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding}"
                                                           FontSize="12"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding}" />
                                                <Button Grid.Column="1"
                                                        Content="🗑"
                                                        FontSize="13" Padding="3,1"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Cursor="Hand"
                                                        Foreground="#CC5555"
                                                        VerticalAlignment="Center"
                                                        Command="{Binding DataContext.RemoveDirectoryCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        IsEnabled="{Binding DataContext.IsNotScanning, RelativeSource={RelativeSource AncestorType=Window}}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>

                        <!-- 输入区：文本框 + 添加按钮 -->
                        <StackPanel Grid.Row="2">
                            <TextBox Text="{Binding NewDirectoryInput, UpdateSourceTrigger=PropertyChanged}"
                                     Height="30" VerticalContentAlignment="Center"
                                     FontSize="12"
                                     IsEnabled="{Binding IsNotScanning}">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <VisualBrush AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                                            <VisualBrush.Visual>
                                                                <TextBlock Text="{Binding L[Main.DirectoryHint], RelativeSource={RelativeSource AncestorType=Window}}"
                                                                           Foreground="#BBB" FontSize="11" Margin="5,0" />
                                                            </VisualBrush.Visual>
                                                        </VisualBrush>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                            <Button Content="{Binding L[Main.AddDirectory]}"
                                    Command="{Binding AddDirectoryCommand}"
                                    Style="{StaticResource SecondaryButton}"
                                    Height="36" Margin="0,4,0,0"
                                    IsEnabled="{Binding IsNotScanning}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 底部操作按钮 -->
                <StackPanel Grid.Row="1" Margin="0,8,0,0">
                    <Button Content="{Binding L[Main.StartScan]}"
                            Command="{Binding StartScanCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Height="36" FontSize="14"
                            Margin="0,0,0,6"
                            IsEnabled="{Binding IsNotScanning}" />
                    <Button Content="{Binding L[Main.StopScan]}"
                            Command="{Binding StopScanCommand}"
                            Height="34" Padding="16,8"
                            Margin="0,0,0,6"
                            IsEnabled="{Binding IsScanning}" />
                    <Button Content="{Binding L[Main.Settings]}"
                            Command="{Binding OpenSettingsCommand}"
                            Height="32" Padding="12,6" FontSize="13"
                            Background="Transparent" BorderThickness="1"
                            BorderBrush="#DDD" Cursor="Hand" />
                </StackPanel>
            </Grid>

            <!-- ===== 右侧面板：扫描结果 ===== -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />   <!-- 摘要栏 -->
                    <RowDefinition Height="*" />      <!-- 结果列表 -->
                </Grid.RowDefinitions>

                <!-- 摘要 + 操作按钮 -->
                <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="10,8"
                        Margin="0,0,0,8"
                        Visibility="{Binding HasResults, Converter={StaticResource BoolToVisibility}}">
                    <Grid>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding FilesFoundText}"
                                       FontSize="13" Margin="0,0,14,0" />
                            <TextBlock FontSize="13" Margin="0,0,14,0">
                                <Run Text="{Binding L[Main.DuplicateGroups]}" />
                                <Run Text="{Binding DuplicateGroups.Count, Mode=OneWay}"
                                     FontWeight="Bold" Foreground="#D32F2F" />
                            </TextBlock>
                            <TextBlock FontSize="13">
                                <Run Text="{Binding L[Main.SpaceSaving]}" />
                                <Run Text="{Binding SpaceSavingText}"
                                     FontWeight="Bold" Foreground="#388E3C" />
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                            <Button Content="{Binding L[Main.SelectAll]}"
                                    Margin="0,0,6,0" Padding="10,5" FontSize="12"
                                    Command="{Binding SelectAllCommand}" />
                            <Button Content="{Binding L[Main.DeselectAll]}"
                                    Margin="0,0,10,0" Padding="10,5" FontSize="12"
                                    Command="{Binding DeselectAllCommand}" />
                            <Button Content="导出 JSON"
                                    Margin="0,0,10,0" Padding="10,5" FontSize="12"
                                    Command="{Binding ExportDuplicatesCommand}" />
                            <Button Content="{Binding L[Main.DeleteSelected]}"
                                    Style="{StaticResource DangerButton}"
                                    Padding="12,6" FontSize="13"
                                    Command="{Binding DeleteSelectedCommand}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 重复组列表 -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding DuplicateGroups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:DuplicateGroup}">
                                <Border Background="White" CornerRadius="8"
                                        Margin="0,0,0,8" Padding="12,10">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <!-- 组标题行 -->
                                        <Grid Grid.Row="0" Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal"
                                                        VerticalAlignment="Center"
                                                        Grid.Column="0">
                                                <TextBlock Text="{Binding GroupTitle}"
                                                           FontSize="15" FontWeight="SemiBold"
                                                           VerticalAlignment="Center" />
                                                <Border Background="#FFE0B2" CornerRadius="10"
                                                        Padding="8,2" Margin="10,0,0,0">
                                                    <TextBlock FontSize="12">
                                                        <Run Text="{Binding DataContext.L[Group.Similarity], RelativeSource={RelativeSource AncestorType=Window}}" />
                                                        <Run Text="{Binding MaxScore, StringFormat={}{0:F0}%}"
                                                             FontWeight="Bold" Foreground="#E65100" />
                                                    </TextBlock>
                                                </Border>
                                                <TextBlock Text="{Binding Summary}"
                                                           FontSize="12" Foreground="#757575"
                                                           VerticalAlignment="Center"
                                                           Margin="10,0,0,0" />
                                            </StackPanel>
                                            <Button Grid.Column="1"
                                                    Content="{Binding DataContext.L[Group.Preview], RelativeSource={RelativeSource AncestorType=Window}}"
                                                    Padding="12,4" FontSize="12"
                                                    Background="Transparent" BorderBrush="#0078D4"
                                                    BorderThickness="1" Cursor="Hand"
                                                    Foreground="#0078D4"
                                                    Command="{Binding DataContext.PreviewGroupCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}" />
                                        </Grid>

                                        <!-- 文件列表 -->
                                        <ItemsControl Grid.Row="1" ItemsSource="{Binding Files}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type models:DuplicateFileItem}">
                                                    <Border CornerRadius="4" Margin="0,0,0,3" Padding="8,7">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="#F7F8FA" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsKeepSuggested}" Value="True">
                                                                        <Setter Property="Background" Value="#F0FFF4" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>

                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" />  <!-- 0: 复选框 -->
                                                                <ColumnDefinition Width="*" />     <!-- 1: 文件信息 -->
                                                                <ColumnDefinition Width="72" />    <!-- 2: 文件大小 -->
                                                                <ColumnDefinition Width="46" />    <!-- 3: 时长 -->
                                                                <ColumnDefinition Width="72" />    <!-- 4: 保留徽章 / 分数 -->
                                                            </Grid.ColumnDefinitions>

                                                            <!-- 复选框 -->
                                                            <CheckBox Grid.Column="0"
                                                                      IsChecked="{Binding IsSelectedForDeletion}"
                                                                      VerticalAlignment="Center"
                                                                      Margin="0,0,8,0" />

                                                            <!-- 文件信息 -->
                                                            <StackPanel Grid.Column="1" Orientation="Vertical">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="{Binding FileInfo.Title}"
                                                                               FontSize="13" FontWeight="SemiBold"
                                                                               TextTrimming="CharacterEllipsis" />
                                                                    <TextBlock Text="{Binding FileInfo.Format}"
                                                                               FontSize="11" Foreground="#999"
                                                                               Margin="8,0,0,0"
                                                                               VerticalAlignment="Center" />
                                                                </StackPanel>
                                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                                    <TextBlock Text="{Binding FileInfo.Artist}"
                                                                               FontSize="12" Foreground="#666"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               MaxWidth="200" />
                                                                    <TextBlock Text=" · " FontSize="12" Foreground="#CCC" />
                                                                    <TextBlock Text="{Binding FileInfo.Album}"
                                                                               FontSize="12" Foreground="#666"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               MaxWidth="200" />
                                                                </StackPanel>
                                                                <TextBlock Text="{Binding FileInfo.FilePath}"
                                                                           FontSize="11" Foreground="#AAA"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           Margin="0,1,0,0"
                                                                           ToolTip="{Binding FileInfo.FilePath}" />
                                                            </StackPanel>

                                                            <!-- 文件大小 -->
                                                            <TextBlock Grid.Column="2"
                                                                       Text="{Binding FileInfo.FileSizeDisplay}"
                                                                       FontSize="12" Foreground="#888"
                                                                       VerticalAlignment="Center"
                                                                       HorizontalAlignment="Right"
                                                                       Margin="4,0" />

                                                            <!-- 时长 -->
                                                            <TextBlock Grid.Column="3"
                                                                       Text="{Binding FileInfo.DurationDisplay}"
                                                                       FontSize="12" Foreground="#888"
                                                                       VerticalAlignment="Center"
                                                                       HorizontalAlignment="Right"
                                                                       Margin="4,0" />

                                                            <!-- 右侧徽章：建议保留（绿）或相似度分数（橙）-->
                                                            <Grid Grid.Column="4" VerticalAlignment="Center">

                                                                <!-- 建议保留徽章（仅 IsKeepSuggested=true 显示）-->
                                                                <Border Background="#E8F5E9" CornerRadius="4"
                                                                        Padding="6,3"
                                                                        Visibility="{Binding IsKeepSuggested, Converter={StaticResource BoolToVisibility}}">
                                                                    <TextBlock Text="{Binding DataContext.L[Group.KeepSuggested], RelativeSource={RelativeSource AncestorType=Window}}"
                                                                               Foreground="#2E7D32"
                                                                               FontSize="11" FontWeight="SemiBold"
                                                                               HorizontalAlignment="Center" />
                                                                </Border>

                                                                <!-- 相似度分数徽章（IsKeepSuggested=false 显示）
                                                                     蓝色 = 传递性匹配（低于阈值，通过其他文件间接关联）
                                                                     橙色 = 直接匹配（≥ 阈值）-->
                                                                <Border CornerRadius="4" Padding="6,3"
                                                                        Visibility="{Binding IsKeepSuggested, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                                                                    <Border.Style>
                                                                        <Style TargetType="Border">
                                                                            <Setter Property="Background" Value="#FFE0B2" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsTransitiveMatch}" Value="True">
                                                                                    <Setter Property="Background" Value="#E3F2FD" />
                                                                                    <Setter Property="ToolTip">
                                                                                        <Setter.Value>
                                                                                            <Binding Path="DataContext.L[Group.TransitiveMatchTooltip]"
                                                                                                     RelativeSource="{RelativeSource AncestorType=Window}" />
                                                                                        </Setter.Value>
                                                                                    </Setter>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Border.Style>
                                                                    <TextBlock FontSize="12" FontWeight="Bold"
                                                                               HorizontalAlignment="Center"
                                                                               Text="{Binding ScoreDisplay}">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Foreground" Value="{Binding SimilarityScore, Converter={StaticResource ScoreToColor}}" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsTransitiveMatch}" Value="True">
                                                                                        <Setter Property="Foreground" Value="#1565C0" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </Border>

                                                            </Grid>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- ===== 底部状态栏 ===== -->
        <Border Grid.Row="1" Background="White" CornerRadius="6"
                Padding="10,6" Margin="0,8,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusText}"
                           FontSize="12" Foreground="#666"
                           VerticalAlignment="Center" />
                <ProgressBar Grid.Column="1" Height="6" Margin="12,0"
                             Value="{Binding OverallProgress}" Maximum="100"
                             Foreground="#0078D4"
                             VerticalAlignment="Center" />
                <TextBlock Grid.Column="2"
                           Text="{Binding OverallProgress, StringFormat={}{0}%}"
                           FontSize="11" Foreground="#888"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</Window>
