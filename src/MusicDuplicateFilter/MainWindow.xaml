<Window x:Class="MusicDuplicateFilter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MusicDuplicateFilter"
        xmlns:models="clr-namespace:MusicDuplicateFilter.Models"
        mc:Ignorable="d"
        Title="Music Duplicate Filter"
        Height="750" Width="1200"
        MinHeight="500" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- 工具栏 -->
            <RowDefinition Height="Auto" />   <!-- 扫描进度 -->
            <RowDefinition Height="*" />      <!-- 结果列表 -->
            <RowDefinition Height="Auto" />   <!-- 状态栏 -->
        </Grid.RowDefinitions>

        <!-- ===== 第1行：工具栏 ===== -->
        <Border Grid.Row="0" Background="White" CornerRadius="6" Padding="12" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Grid.Column="0">
                    <TextBlock Text="扫描目录:" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="14" />
                    <TextBox Text="{Binding ScanDirectory, UpdateSourceTrigger=PropertyChanged}"
                             Width="350" Height="32" VerticalContentAlignment="Center"
                             VerticalAlignment="Center" FontSize="13"
                             IsEnabled="{Binding IsNotScanning}" />
                    <Button Command="{Binding BrowseDirectoryCommand}"
                            Content="浏览..."
                            Style="{StaticResource PrimaryButton}"
                            Margin="8,0,8,0" Height="32"
                            IsEnabled="{Binding IsNotScanning}" />
                    <Button Command="{Binding StartScanCommand}"
                            Content="开始扫描"
                            Style="{StaticResource PrimaryButton}"
                            Height="32" Padding="20,8"
                            IsEnabled="{Binding IsNotScanning}" />
                    <Button Command="{Binding StopScanCommand}"
                            Content="停止"
                            Height="32" Padding="16,8"
                            Margin="8,0,0,0"
                            Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisibility}}"
                            IsEnabled="{Binding IsScanning}" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Column="3">
                    <Button Command="{Binding OpenSettingsCommand}"
                            Content="⚙ 设置"
                            Height="32" Padding="12,6" FontSize="13"
                            Background="Transparent" BorderThickness="1"
                            BorderBrush="#DDD" Cursor="Hand" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== 第2行：进度信息 ===== -->
        <Border Grid.Row="1" Margin="0,0,0,8"
                Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisibility}}">
            <StackPanel Margin="0,4">
                <TextBlock Text="{Binding StatusText}" FontSize="13" Margin="0,0,0,4" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ProgressBar Grid.Column="0" Height="8"
                                 Value="{Binding ScanProgress}" Maximum="100"
                                 Foreground="#0078D4" />
                    <TextBlock Grid.Column="1" Margin="12,0,0,0" FontSize="12"
                               Text="{Binding ScanProgress, StringFormat={}{0}%}" />
                </Grid>
            </StackPanel>
        </Border>

        <!-- ===== 第3行：结果区域 ===== -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- 结果摘要栏 -->
            <Border Grid.Row="0" Margin="0,0,0,6" Padding="8,6"
                    Visibility="{Binding HasResults, Converter={StaticResource BoolToVisibility}}">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <TextBlock Text="{Binding FilesFoundText}" FontSize="13" Margin="0,0,16,0" />
                        <TextBlock FontSize="13">
                            <Run Text="重复组: " />
                            <Run Text="{Binding DuplicateGroups.Count}" FontWeight="Bold" Foreground="#D32F2F" />
                        </TextBlock>
                        <TextBlock FontSize="13" Margin="16,0,0,0">
                            <Run Text="可节省: " />
                            <Run Text="{Binding SpaceSavingText}" FontWeight="Bold" Foreground="#388E3C" />
                        </TextBlock>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="全选" Margin="0,0,6,0" Padding="10,4" FontSize="12"
                                Command="{Binding SelectAllCommand}"
                                Visibility="{Binding HasResults, Converter={StaticResource BoolToVisibility}}" />
                        <Button Content="取消全选" Margin="0,0,12,0" Padding="10,4" FontSize="12"
                                Command="{Binding DeselectAllCommand}"
                                Visibility="{Binding HasResults, Converter={StaticResource BoolToVisibility}}" />
                        <Button Content="预览选中组" Margin="0,0,6,0" Padding="10,4" FontSize="12"
                                Command="{Binding PreviewGroupCommand}"
                                IsEnabled="{Binding SelectedGroup, Converter={StaticResource BoolToVisibility}}" />
                        <Button Content="🗑 删除选中文件"
                                Style="{StaticResource DangerButton}"
                                Padding="12,6" FontSize="13"
                                Command="{Binding DeleteSelectedCommand}"
                                Visibility="{Binding HasResults, Converter={StaticResource BoolToVisibility}}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 重复组列表 -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding DuplicateGroups}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:DuplicateGroup}">
                            <Border Background="White" CornerRadius="6" Margin="0,0,0,6" Padding="12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- 组标题 -->
                                    <Grid Grid.Row="0" Margin="0,0,0,8">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding GroupTitle}"
                                                       FontSize="16" FontWeight="SemiBold"
                                                       VerticalAlignment="Center" />
                                            <Border Background="#FFE0B2" CornerRadius="10"
                                                    Padding="8,2" Margin="12,0,0,0">
                                                <TextBlock FontSize="12">
                                                    <Run Text="相似度: " />
                                                    <Run Text="{Binding MaxScore, StringFormat={}{0:F0}%}"
                                                         FontWeight="Bold" Foreground="#E65100" />
                                                </TextBlock>
                                            </Border>
                                            <TextBlock Text="{Binding Summary}"
                                                       FontSize="12" Foreground="#757575"
                                                       VerticalAlignment="Center" Margin="12,0,0,0" />
                                        </StackPanel>
                                    </Grid>

                                    <!-- 文件列表 -->
                                    <ItemsControl Grid.Row="1" ItemsSource="{Binding Files}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type models:DuplicateFileItem}">
                                                <Border Background="#FAFAFA" CornerRadius="4"
                                                        Margin="0,0,0,4" Padding="10,8">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <!-- 建议保留标记 -->
                                                        <Border Grid.Column="0"
                                                                Background="{Binding IsKeepSuggested, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                                                            <TextBlock Text="⭐ 建议保留"
                                                                       Foreground="#FF6F00"
                                                                       FontSize="12"
                                                                       Margin="0,0,8,0"
                                                                       Visibility="{Binding IsKeepSuggested, Converter={StaticResource BoolToVisibility}}" />
                                                        </Border>

                                                        <!-- 复选框（非保留文件） -->
                                                        <CheckBox Grid.Column="1"
                                                                  IsChecked="{Binding IsSelectedForDeletion}"
                                                                  VerticalAlignment="Center"
                                                                  Margin="0,0,8,0"
                                                                  Visibility="{Binding IsKeepSuggested, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}" />

                                                        <!-- 文件信息 -->
                                                        <StackPanel Grid.Column="2" Orientation="Vertical">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="{Binding FileInfo.Title}"
                                                                           FontSize="13" FontWeight="SemiBold"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           MaxWidth="400" />
                                                                <TextBlock Text="{Binding FileInfo.Format}"
                                                                           FontSize="11" Foreground="#999"
                                                                           Margin="8,0,0,0"
                                                                           VerticalAlignment="Center">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Text" Value="" />
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </StackPanel>
                                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                                <TextBlock Text="{Binding FileInfo.Artist}"
                                                                           FontSize="12" Foreground="#666"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           MaxWidth="200" />
                                                                <TextBlock Text=" · " FontSize="12" Foreground="#CCC"
                                                                           Visibility="{Binding FileInfo.Artist, Converter={StaticResource BoolToVisibility}}" />
                                                                <TextBlock Text="{Binding FileInfo.Album}"
                                                                           FontSize="12" Foreground="#666"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           MaxWidth="200" />
                                                            </StackPanel>
                                                            <TextBlock Text="{Binding FileInfo.FilePath}"
                                                                       FontSize="11" Foreground="#AAA"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       MaxWidth="600" Margin="0,1,0,0" />
                                                        </StackPanel>

                                                        <!-- 文件大小 -->
                                                        <TextBlock Grid.Column="3"
                                                                   Text="{Binding FileInfo.FileSizeDisplay}"
                                                                   FontSize="12" Foreground="#888"
                                                                   VerticalAlignment="Center"
                                                                   Margin="12,0,0,0" />

                                                        <!-- 时长 -->
                                                        <TextBlock Grid.Column="4"
                                                                   Text="{Binding FileInfo.DurationDisplay}"
                                                                   FontSize="12" Foreground="#888"
                                                                   VerticalAlignment="Center"
                                                                   Margin="12,0,0,0" />

                                                        <!-- 相似度分数 -->
                                                        <Border Grid.Column="5"
                                                                CornerRadius="4" Padding="6,2"
                                                                Margin="12,0,0,0"
                                                                Visibility="{Binding IsKeepSuggested, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                                                            <Border.Background>
                                                                <SolidColorBrush Color="#FFE0B2" />
                                                            </Border.Background>
                                                            <TextBlock Text="{Binding ScoreDisplay}"
                                                                       FontSize="12" FontWeight="Bold"
                                                                       Foreground="{Binding SimilarityScore, Converter={StaticResource ScoreToColor}}" />
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- ===== 第4行：状态栏 ===== -->
        <Border Grid.Row="3" Margin="0,8,0,0" Padding="8,4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="#666" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
