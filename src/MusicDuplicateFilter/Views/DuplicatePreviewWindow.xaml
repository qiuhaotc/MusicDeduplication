<Window x:Class="MusicDuplicateFilter.Views.DuplicatePreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:MusicDuplicateFilter.Models"
        Title="文件预览"
        Height="600" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- 保留文件 -->
        <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="16">
            <StackPanel>
                <TextBlock Text="⭐ 保留文件" FontSize="18" FontWeight="Bold"
                           Foreground="#2E7D32" Margin="0,0,0,12" />

                <Border Background="#E8F5E9" CornerRadius="4" Padding="12" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock FontSize="15" FontWeight="SemiBold"
                                   Text="{Binding KeepFile.FileInfo.Title}"
                                   TextWrapping="Wrap" />
                        <TextBlock FontSize="13" Foreground="#555" Margin="0,4,0,0">
                            <Run Text="艺术家: " />
                            <Run Text="{Binding KeepFile.FileInfo.Artist, Mode=OneWay}" />
                        </TextBlock>
                        <TextBlock FontSize="13" Foreground="#555">
                            <Run Text="专辑: " />
                            <Run Text="{Binding KeepFile.FileInfo.Album, Mode=OneWay}" />
                        </TextBlock>
                        <TextBlock FontSize="12" Foreground="#888" Margin="0,2,0,0">
                            <Run Text="大小: " />
                            <Run Text="{Binding KeepFile.FileInfo.FileSizeDisplay, Mode=OneWay}" />
                        </TextBlock>
                        <TextBlock FontSize="12" Foreground="#888">
                            <Run Text="时长: " />
                            <Run Text="{Binding KeepFile.FileInfo.DurationDisplay, Mode=OneWay}" />
                        </TextBlock>
                        <TextBlock FontSize="11" Foreground="#AAA" Margin="0,2,0,0"
                                   Text="{Binding KeepFile.FileInfo.FilePath}"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Border>

                <StackPanel Orientation="Horizontal">
                    <Button Content="▶ 播放" Command="{Binding PlayKeepFileCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Width="100" Height="36" />
                    <Button Content="📂 打开位置" Command="{Binding OpenKeepInExplorerCommand}"
                            Width="110" Height="36" Margin="8,0,0,0"
                            Background="Transparent" BorderThickness="1" BorderBrush="#DDD"
                            Cursor="Hand" FontSize="13" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 分隔线 -->
        <Border Grid.Column="1" Width="2" Background="#E0E0E0" Margin="12,0" />

        <!-- 重复文件列表 -->
        <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="16">
            <StackPanel>
                <TextBlock FontSize="18" FontWeight="Bold" Foreground="#D32F2F" Margin="0,0,0,12">
                    <Run Text="重复文件 (" />
                    <Run Text="{Binding DuplicateFiles.Count, Mode=OneWay}" />
                    <Run Text=")" />
                </TextBlock>

                <ScrollViewer MaxHeight="380" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding DuplicateFiles}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:DuplicateFileItem}">
                                <Border Background="#FFF3F3" CornerRadius="4"
                                        Padding="10" Margin="0,0,0,8"
                                        Cursor="Hand">
                                    <Border.InputBindings>
                                        <MouseBinding Gesture="LeftClick"
                                                      Command="{Binding DataContext.PlaySelectedDuplicateCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                    </Border.InputBindings>
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <Border Background="#FFCDD2" CornerRadius="10"
                                                    Padding="6,1" Margin="0,0,8,0">
                                                <TextBlock Text="{Binding ScoreDisplay}"
                                                           FontSize="11" FontWeight="Bold"
                                                           Foreground="#B71C1C" />
                                            </Border>
                                            <TextBlock FontSize="13" FontWeight="SemiBold"
                                                       Text="{Binding FileInfo.Title}"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxWidth="250" />
                                        </StackPanel>
                                        <TextBlock FontSize="11" Foreground="#888"
                                                   Margin="0,2,0,0">
                                            <Run Text="艺术家: " />
                                            <Run Text="{Binding FileInfo.Artist, Mode=OneWay}" />
                                        </TextBlock>
                                        <TextBlock FontSize="11" Foreground="#AAA"
                                                   Text="{Binding FileInfo.FilePath}"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxWidth="300" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
        </Border>
    </Grid>
</Window>
