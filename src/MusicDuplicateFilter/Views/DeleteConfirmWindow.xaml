<Window x:Class="MusicDuplicateFilter.Views.DeleteConfirmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="确认删除"
        SizeToContent="Height" MaxHeight="620" Width="580"
        MinHeight="200" ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 提示文字 -->
        <TextBlock Grid.Row="0" x:Name="HeaderText"
                   FontSize="14" FontWeight="SemiBold"
                   Foreground="#D32F2F"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12" />

        <!-- 文件列表 -->
        <Border Grid.Row="1" Background="White" CornerRadius="6"
                BorderBrush="#E0E0E0" BorderThickness="1"
                Margin="0,0,0,16">
            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="400">
                <ItemsControl x:Name="FileList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="12,7">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="🗑 "
                                           FontSize="14" VerticalAlignment="Top"
                                           Margin="0,1,6,0" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding FileName}"
                                               FontSize="13" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding FilePath}"
                                               FontSize="11" Foreground="#888"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding FilePath}" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- 按钮行 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="CancelBtn" Content="取消"
                    Width="88" Height="34" Margin="0,0,10,0"
                    Click="CancelBtn_Click"
                    Background="Transparent" BorderThickness="1"
                    BorderBrush="#CCC" Cursor="Hand" FontSize="13" />
            <Button x:Name="ConfirmBtn" Content="✔ 确认删除"
                    Width="110" Height="34"
                    Click="ConfirmBtn_Click"
                    Style="{StaticResource DangerButton}"
                    FontSize="13" />
        </StackPanel>
    </Grid>
</Window>
